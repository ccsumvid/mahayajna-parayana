{
  "name": "gita-pacer",
  "version": "0.8.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --arm64 --x64 --win",
    "build:mac": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.gitapacer.app",
    "productName": "Gita Parayana Pace Helper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "data/**/*",
      "img/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.education"
    },
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  }
}
